#!/bin/bash

PROJECT_DIR="$HOME/OS-SE-p20240046/final-exam/partE_automation/sample_project"
BACKUP_DIR="$HOME/OS-SE-p20240046/final-exam/partE_automation/project_backups"

# Create a timestamped, compressed archive (tar.gz)
TIMESTAMP=$(date +"%Y%m%d_%H%M%S")
tar -czvf "$BACKUP_DIR/backup_$TIMESTAMP.tar.gz" -C "$PROJECT_DIR" .

# Keep only the newest 4 archives, prune the rest
cd "$BACKUP_DIR" || exit
ls -t | tail -n +5 | xargs -r rm -f

echo "Backup created and retention policy applied."
ls -l "$BACKUP_DIR"
