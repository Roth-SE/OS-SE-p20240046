#!/bin/bash
if [ -z "$1" ]; then
    echo "Error: Output file required."
    exit 1
fi

TODAY=$(date +"%Y-%m-%d")
TOKEN="ONCEKEY"

# CURVEBALL: Idempotent check
if grep -q "${TODAY}.*${TOKEN}" "$1" 2>/dev/null; then
    echo "Skipping: Token ${TOKEN} already found for ${TODAY}."
    exit 0
fi

echo "Job ran at: $(date +"%Y-%m-%d %H:%M:%S") | Token: ${TOKEN}" >> "$1"
echo "Job executed successfully."
